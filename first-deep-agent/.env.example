# Agent model routing. Use provider:model format.
# Main/default + long-context research: Ollama Cloud DeepSeek V4 Flash.
# Coding/review/critic work: Ollama Cloud Kimi K2.7 Code.
DEEP_AGENT_MODEL=ollama:deepseek-v4-flash:cloud
DEEP_AGENT_RESEARCH_MODEL=ollama:deepseek-v4-flash:cloud
DEEP_AGENT_CODING_MODEL=ollama:kimi-k2.7-code:cloud
DEEP_AGENT_CRITIC_MODEL=ollama:kimi-k2.7-code:cloud

# OpenAI provider.
OPENAI_API_KEY=your-openai-api-key
# Optional: only set this if you use an OpenAI-compatible gateway/proxy.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama provider. For Ollama Cloud, set your API key and hosted base URL.
OLLAMA_API_KEY=your-ollama-api-key
# Local Ollama usually uses http://localhost:11434.
# Ollama Cloud / hosted Ollama may use a provider-specific hosted URL.
OLLAMA_HOST=https://ollama.com
OLLAMA_BASE_URL=https://ollama.com

# Comma-separated domains that Deep Research may request human-approved access to.
# Every fetch with fetch_approved_web_url still requires explicit human approval.
APPROVED_WEB_DOMAINS=docs.elevenlabs.io,elevenlabs.io,elevenlabs.com,openai.com,platform.openai.com,ollama.com,docs.livekit.io,livekit.io,developers.telnyx.com,telnyx.com,developers.deepgram.com,deepgram.com

# LangSmith / LangGraph Cloud Deployments.
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_WORKSPACE_ID=your-workspace-id
# Required by LangGraph Deployment CLI for org-scoped service keys.
LANGSMITH_TENANT_ID=your-workspace-id
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=langgraph-langchain-server-deploy-dev
# EU LangSmith/LangGraph host.
LANGGRAPH_HOST_URL=https://eu.api.host.langchain.com

# Optional sandbox settings used by the template when LangSmith execution runtime is available.
SANDBOX_TEMPLATE_NAME=deep-agent
SANDBOX_TEMPLATE_IMAGE=python:3
